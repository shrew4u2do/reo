# Copy this file to .env and fill in your Reolink Home Hub details.
# (.env is gitignored — your password stays local.)

REOLINK_HOST=192.168.1.xxx
REOLINK_PORT=443
REOLINK_USERNAME=admin
REOLINK_PASSWORD=your-hub-password
# Use HTTPS (the Hub uses a self-signed cert; verification is disabled in code).
REOLINK_USE_HTTPS=true
